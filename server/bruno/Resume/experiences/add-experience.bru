meta {
  name: Add Experience
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/api/resume/experiences
  body: json
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body {
  {
    "type": "Part-time",
    "company": "Google",
    "role": "Software Engineer",
    "duration": "2020-Present",
    "details": "Developed and maintained various software."
  }
}
