infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl

# Terraform backup files
*.backup
*.bak

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# AWS credentials
.aws/
credentials
.aws/config

# SSH keys
*.pem
*.key
id_rsa*
