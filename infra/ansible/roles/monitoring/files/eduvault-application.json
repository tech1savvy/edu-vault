{
  "title": "EduVault Application",
  "uid": "eduvault-application",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["eduvault", "application"],
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "editable": true,
  "panels": [
    {
      "title": "HTTP Request Rate - Backend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(http_requests_total[2m])", "legendFormat": "All requests" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "HTTP Error Rate - Backend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(http_requests_total{status=~\"5..\"}[2m])", "legendFormat": "5xx errors" },
        { "expr": "rate(http_requests_total{status=~\"4..\"}[2m])", "legendFormat": "4xx errors" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "HTTP Request Duration - Backend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(http_request_duration_seconds_sum[2m]) / rate(http_request_duration_seconds_count[2m])", "legendFormat": "Avg duration" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "ML Service Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rate(http_requests_total{job=\"ml_service\"}[2m])", "legendFormat": "Total requests" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "Embedding Generation Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "rate(embedding_duration_seconds_sum[2m]) / rate(embedding_duration_seconds_count[2m])", "legendFormat": "Avg embedding time" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "HTTP Request Duration - ML",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "rate(http_request_duration_seconds_sum{job=\"ml_service\"}[2m]) / rate(http_request_duration_seconds_count{job=\"ml_service\"}[2m])", "legendFormat": "Avg duration" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Service Uptime (up)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    }
  ]
}
