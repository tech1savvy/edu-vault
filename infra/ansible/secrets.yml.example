---
# Database settings
postgres_db: edu_vault
postgres_user: postgres
postgres_password: changeme_secure_password

# JWT Secret (use a long random string)
jwt_secret: changeme_jwt_secret_key

# Qdrant collection name
qdrant_collection: eduvault

# Test account credentials
test_user_email: student1@example.com
test_user_password: password123

# Monitoring credentials
grafana_admin_user: admin
grafana_admin_password: changeme_grafana_password

# Alerting
alert_email: admin@example.com
smtp_host: ""
smtp_from: alertmanager@eduvault.local
